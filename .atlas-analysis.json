  "keyFeatures": [
    "x402 payment protocol integration for paid AI agent calls",
    "Multi-agent marketplace with 7 specialist agents (Oracle, Scout, News, Yield, Tokenomics, NFT, Perp)",
    "Pinion-powered procurement routing with provider scoring and fallback attempts",
    "Policy controls: freeze/unfreeze agents, spend limits, allowlists, per-call caps",
    "CDP wallet-based buyer/seller wallet management",
    "Real-time dashboard with receipts, spend tracking, and activity logs",
    "Smart contract system (AgentRegistry, Escrow, PolicyVault) on Base Sepolia",
    "Gemini AI orchestration with automatic tool selection",
    "Supabase-backed persistence for chats, ratings, and payment logs"
  ],
  "publicApiSurface": [
    "POST /query - Submit paid queries with USDC payment verification",
    "GET /providers - List all available agent providers with pricing",
    "GET /dashboard/stats - Agent performance statistics and treasury balance",
    "GET /dashboard/activity - Recent query activity and payment logs",
    "GET /dashboard/spend - Session spend summary with receipts and trace",
    "POST /x402/procurement/rank - Rank candidate x402 service providers",
    "POST /x402/procurement/execute - Execute procurement with fallback routing",
    "GET /treasury/balance/:address - Check wallet balance via Pinion",
    "POST /treasury/send - Send USDC/ETH via Pinion",
    "POST /treasury/trade - Token swap via Pinion",
    "POST /admin/policy/:agentId/freeze - Freeze/unfreeze agent",
    "PATCH /admin/policy/:agentId - Update policy limits",
    "POST /chat/sessions - Create chat session",
    "GET /chat/sessions/:sessionId/messages - Get chat history",
    "POST /ratings - Rate agent response",
    "GET /agent/rating - Get agent rating statistics"
  ]
}
